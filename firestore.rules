rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── users/{uid} ──
    // Read/write: owner only; uid field is immutable
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.data.uid == uid;
    }

    // ── groups/{groupId} ──
    match /groups/{groupId} {
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.memberUids;

      // Any authenticated user can create, if they include themselves and status is 'waiting'
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.memberUids
                    && request.resource.data.status == 'waiting';

      // Members can: (a) join (add self to memberUids), or (b) update own nickname
      // Protected fields (status, hostUid, maxMembers, gameStartedAt, gameEndedAt) cannot change
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.memberUids
                    // Protected fields must not change
                    && request.resource.data.status == resource.data.status
                    && request.resource.data.hostUid == resource.data.hostUid
                    && request.resource.data.maxMembers == resource.data.maxMembers
                    && (!('gameStartedAt' in resource.data) || request.resource.data.gameStartedAt == resource.data.gameStartedAt)
                    && (!('gameEndedAt' in resource.data) || request.resource.data.gameEndedAt == resource.data.gameEndedAt)
                    && (
                      // Case 1: Joining — add self to memberUids (+ update memberNicknames allowed)
                      (
                        request.resource.data.memberUids.hasAll(resource.data.memberUids)
                        && request.resource.data.memberUids.size() == resource.data.memberUids.size() + 1
                        && request.auth.uid in request.resource.data.memberUids
                      )
                      ||
                      // Case 2: Updating own nickname only
                      (
                        request.resource.data.memberUids == resource.data.memberUids
                        && request.resource.data.memberNicknames.diff(resource.data.memberNicknames).affectedKeys().hasOnly([request.auth.uid])
                      )
                    );

      allow delete: if false;

      // ── bombs subcollection ──
      // Read: group members only; Write: Functions only (via Admin SDK)
      match /bombs/{bombId} {
        allow read: if request.auth != null
                    && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberUids;
        allow write: if false;
      }
    }

    // ── shopItems/{itemId} ──
    // Read: any authenticated user; Write: blocked
    match /shopItems/{itemId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
